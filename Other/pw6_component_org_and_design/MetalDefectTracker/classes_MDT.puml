@startuml classes_MDT
set namespaceSeparator none
class "AccountsConfig" as apps.accounts.apps.AccountsConfig {
  name : str
}
class "AddManualDefectCommand" as apps.verification.commands.AddManualDefectCommand {
  author : str | None
  bbox
  custom_name : str | None
  description : str | None
  label : str
  marker
  execute() -> str
}
class "AdministrationConfig" as apps.administration.apps.AdministrationConfig {
  name : str
}
class "AdministrationPolicy" as apps.administration.models.AdministrationPolicy {
  camera_resolution : str
  capture_interval_seconds : int
  detection_threshold : float
  manual_verification_enabled : bool
  rbac_policy
  can_manage_configuration(role: str) -> bool
}
class "AnalyticsConfig" as apps.analytics.apps.AnalyticsConfig {
  name : str
}
class "AnalyticsReportService" as apps.analytics.models.AnalyticsReportService {
  rbac_policy
  reception_service
  verification_workflow
  build_summary(role: str, image_path: str) -> dict[str, object]
}
class "AuditEntry" as apps.verification.commands.AuditEntry {
  action_name : str
  control_record_id : int
  description : str
  operator_id : int
}
class "AuditLog" as apps.verification.commands.AuditLog {
  {abstract}add_entry(entry: AuditEntry) -> None
}
class "BoundingBox" as apps.detection.defects.BoundingBox {
  height : int
  width : int
  x : int
  y : int
}
class "ConfirmDefectsCommand" as apps.verification.commands.ConfirmDefectsCommand {
  execute() -> str
}
class "Defect" as apps.detection.defects.Defect {
  bbox
  code : str
  confidence : float
  display_name : str
  source : str
  describe() -> str
  is_manual() -> bool
}
class "DefectFactory" as apps.detection.factories.DefectFactory {
  {abstract}create_defect(prediction: ModelPrediction) -> Defect
  register_prediction(prediction: ModelPrediction) -> Defect
}
class "DefectFactoryRegistry" as apps.detection.factories.DefectFactoryRegistry {
  get_factory(label: str) -> DefectFactory
  register(label: str, factory: DefectFactory) -> None
}
class "DefinedDefect" as apps.detection.defects.DefinedDefect {
  code : str
  display_name : str
}
class "DefinedDefectFactory" as apps.detection.factories.DefinedDefectFactory {
  create_defect(prediction: ModelPrediction) -> Defect
}
class "DetectionApplicationService" as apps.detection.services.DetectionApplicationService {
  prediction_provider
  result_builder
  detect(image_path: str, threshold: float) -> list[Defect]
}
class "DetectionConfig" as apps.detection.apps.DetectionConfig {
  name : str
}
class "DetectionResultBuilder" as apps.detection.services.DetectionResultBuilder {
  registry
  build_defects(predictions: Iterable[ModelPrediction]) -> list[Defect]
}
class "DetectionWorkflow" as apps.detection.models.DetectionWorkflow {
  administration_policy
  reception_service
  prepare_detection_request(image_path: str) -> dict[str, object]
}
class "ExcludeDefectCommand" as apps.verification.commands.ExcludeDefectCommand {
  defect
  execute() -> str
}
class "ExternalMLDetectionService" as apps.detection.external_client.ExternalMLDetectionService {
  analyze_image(image_path: str, threshold: float) -> dict
}
class "ImageReceptionService" as apps.receiver.models.ImageReceptionService {
  administration_policy
  receive(image_path: str) -> dict[str, str | int]
}
class "<color:red>InvalidManualDefectError</color>" as apps.detection.defects.InvalidManualDefectError {
}
class "MLServiceAdapter" as apps.detection.adapters.MLServiceAdapter {
  adaptee
  get_predictions(image_path: str, threshold: float) -> list[ModelPrediction]
}
class "ManualDefectMarker" as apps.verification.services.ManualDefectMarker {
  registry
  mark(label: str, bbox: BoundingBox, confidence: float, custom_name: str | None, author: str | None, description: str | None) -> Defect
}
class "ModelPrediction" as apps.detection.defects.ModelPrediction {
  bbox
  confidence : float
  label : str
  source : str
}
class "NullAuditLog" as apps.verification.commands.NullAuditLog {
  add_entry(entry: AuditEntry) -> None
}
class "OtherDefect" as apps.detection.defects.OtherDefect {
  code : str
  display_name : str
  describe() -> str
}
class "OtherDefectFactory" as apps.detection.factories.OtherDefectFactory {
  author
  custom_name
  description : NoneType
  create_defect(prediction: ModelPrediction) -> Defect
}
class "PredictionProvider" as apps.detection.adapters.PredictionProvider {
  {abstract}get_predictions(image_path: str, threshold: float) -> list[ModelPrediction]
}
class "RBACPolicy" as apps.accounts.models.RBACPolicy {
  can_manage_system(role: str) -> bool
  can_verify(role: str) -> bool
  can_view_analytics(role: str) -> bool
}
class "ReceiverConfig" as apps.receiver.apps.ReceiverConfig {
  name : str
}
class "RejectDetectionCommand" as apps.verification.commands.RejectDetectionCommand {
  execute() -> str
}
class "TestNameConfig" as apps.apps.TestNameConfig {
  name : str
}
class "<color:red>UnknownPredictionLabelError</color>" as apps.detection.defects.UnknownPredictionLabelError {
}
class "VerificationAuditLog" as apps.verification.commands.VerificationAuditLog {
  entries : list[AuditEntry]
  add_entry(entry: AuditEntry) -> None
}
class "VerificationCommand" as apps.verification.commands.VerificationCommand {
  session
  {abstract}execute() -> str
}
class "VerificationCommandInvoker" as apps.verification.commands.VerificationCommandInvoker {
  audit_log
  execute_command() -> str
  set_command(command: VerificationCommand) -> None
}
class "VerificationConfig" as apps.verification.apps.VerificationConfig {
  name : str
}
class "VerificationSession" as apps.verification.services.VerificationSession {
  control_record_id : int
  defects : list[Defect]
  operator_id : int
  status
  add_manual_defect(defect: Defect) -> None
  confirm_defects() -> None
  exclude_defect(defect: Defect) -> None
  reject_detection() -> None
}
class "VerificationStatus" as apps.verification.services.VerificationStatus {
  name
}
class "VerificationWorkflow" as apps.verification.models.VerificationWorkflow {
  administration_policy
  detection_workflow
  rbac_policy
  can_start_verification(role: str, image_path: str) -> bool
}
apps.detection.adapters.MLServiceAdapter --|> apps.detection.adapters.PredictionProvider
apps.detection.defects.DefinedDefect --|> apps.detection.defects.Defect
apps.detection.defects.OtherDefect --|> apps.detection.defects.Defect
apps.detection.factories.DefinedDefectFactory --|> apps.detection.factories.DefectFactory
apps.detection.factories.OtherDefectFactory --|> apps.detection.factories.DefectFactory
apps.verification.commands.AddManualDefectCommand --|> apps.verification.commands.VerificationCommand
apps.verification.commands.ConfirmDefectsCommand --|> apps.verification.commands.VerificationCommand
apps.verification.commands.ExcludeDefectCommand --|> apps.verification.commands.VerificationCommand
apps.verification.commands.NullAuditLog --|> apps.verification.commands.AuditLog
apps.verification.commands.RejectDetectionCommand --|> apps.verification.commands.VerificationCommand
apps.verification.commands.VerificationAuditLog --|> apps.verification.commands.AuditLog
apps.administration.models.AdministrationPolicy --> apps.accounts.models.RBACPolicy : rbac_policy
apps.analytics.models.AnalyticsReportService --> apps.accounts.models.RBACPolicy : rbac_policy
apps.verification.models.VerificationWorkflow --> apps.accounts.models.RBACPolicy : rbac_policy
apps.detection.models.DetectionWorkflow --> apps.administration.models.AdministrationPolicy : administration_policy
apps.receiver.models.ImageReceptionService --> apps.administration.models.AdministrationPolicy : administration_policy
apps.verification.models.VerificationWorkflow --> apps.administration.models.AdministrationPolicy : administration_policy
apps.detection.defects.Defect --> apps.detection.defects.BoundingBox : bbox
apps.detection.defects.ModelPrediction --> apps.detection.defects.BoundingBox : bbox
apps.detection.services.DetectionResultBuilder --> apps.detection.factories.DefectFactoryRegistry : registry
apps.verification.services.ManualDefectMarker --> apps.detection.factories.DefectFactoryRegistry : registry
apps.verification.models.VerificationWorkflow --> apps.detection.models.DetectionWorkflow : detection_workflow
apps.detection.services.DetectionApplicationService --> apps.detection.services.DetectionResultBuilder : result_builder
apps.analytics.models.AnalyticsReportService --> apps.receiver.models.ImageReceptionService : reception_service
apps.detection.models.DetectionWorkflow --> apps.receiver.models.ImageReceptionService : reception_service
apps.verification.commands.VerificationCommandInvoker --> apps.verification.commands.VerificationAuditLog : audit_log
apps.analytics.models.AnalyticsReportService --> apps.verification.models.VerificationWorkflow : verification_workflow
apps.verification.services.VerificationSession --> apps.verification.services.VerificationStatus : status
apps.detection.adapters.PredictionProvider --o apps.detection.services.DetectionApplicationService : prediction_provider
apps.detection.defects.BoundingBox --o apps.verification.commands.AddManualDefectCommand : bbox
apps.detection.defects.Defect --o apps.verification.commands.ExcludeDefectCommand : defect
apps.detection.external_client.ExternalMLDetectionService --o apps.detection.adapters.MLServiceAdapter : adaptee
apps.verification.services.ManualDefectMarker --o apps.verification.commands.AddManualDefectCommand : marker
apps.verification.services.VerificationSession --o apps.verification.commands.VerificationCommand : session
@enduml
